# ── OpenAI（僅伺服器端，切勿加 NEXT_PUBLIC_ 前綴）──
OPENAI_API_KEY=sk-your-key-here

# 可選：指定圖像模型（預設依序嘗試 gpt-image-1 → gpt-image-1-mini → dall-e-2）
# OPENAI_IMAGE_MODEL=gpt-image-1

# ── 登入 Session（生產環境請設為 32 字元以上隨機字串）──
AUTH_SECRET=change-me-to-a-long-random-string

# ── Upstash Redis（Vercel 生產環境必填；本機可省略，會改用 data/ 資料夾）──
# 在 Vercel Dashboard → Integrations → Upstash Redis 安裝後會自動填入
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── API 安全：允許的網域（僅此網址可呼叫 API，逗號分隔）──
ALLOWED_ORIGINS=https://plan-lake-eight.vercel.app

# ── Rate Limit：每裝置每分鐘 API 次數上限（全站共用）──
RATE_LIMIT_MAX_REQUESTS=2
RATE_LIMIT_WINDOW_MS=60000
